# ── WhatsApp Cloud API (Meta) ─────────────────────────────────────────────────
# Get these from: https://developers.facebook.com → Your App → WhatsApp → API Setup

# Long-lived access token (or temporary 24h token for testing)
WHATSAPP_API_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Phone Number ID shown in WhatsApp API Setup dashboard
WHATSAPP_PHONE_NUMBER_ID=123456789012345

# Comma-separated recipient numbers — country code + number, NO + sign
# India example: 91 (country code) + 10-digit mobile
WHATSAPP_RECIPIENTS=919876543210,919876543211,919876543212

# Human-readable camera name shown in alert messages
WHATSAPP_CAMERA_LABEL=Gate-2 Camera

# Min seconds between alerts to the same number (default 300 = 5 min)
# Set lower for testing, e.g. 30
WHATSAPP_COOLDOWN_S=300

# ── PPE detection overrides ────────────────────────────────────────────────────
# PPE_CONF_THRESHOLD=0.10
# PPE_REQUIRED=helmet,safety_vest
# PPE_ALERT_FRAMES=20
# PPE_ALERT_COOLDOWN=60
# PPE_DEVICE=cuda
